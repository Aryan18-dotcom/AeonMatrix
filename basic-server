app.post('/api/config', (req, res) => {
  try {
    const {
      defaultMedium = 'site',
      email = '',
      telegramBotToken = '',
      telegramOwnerId = '',
      telegramAllowedIds = []
    } = req.body;

    const normalizedAllowedIds = Array.isArray(telegramAllowedIds)
      ? telegramAllowedIds.map(id => String(id).trim()).filter(Boolean)
      : String(telegramAllowedIds || '')
          .split(',')
          .map(id => id.trim())
          .filter(Boolean);

    const cfg = {
      defaultMedium: ['site', 'telegram', 'email'].includes(defaultMedium)
        ? defaultMedium
        : 'site',
      email: String(email || ''),
      telegramBotToken: String(telegramBotToken || ''),
      telegramOwnerId: String(telegramOwnerId || ''),
      telegramAllowedIds: normalizedAllowedIds
    };

    writeConfig(cfg);

    // Re-initialize bot when token changes
    setupTelegramBotFromConfig();

    res.json({ success: true, config: cfg });
  } catch (err) {
    console.error('❌ config POST error:', err.message);
    res.status(500).json({ error: 'Failed to save config.' });
  }
});

app.post('/api/parse-prompt', async (req, res) => {
  const { prompt } = req.body;
  try {
    const obj = await parsePrompt(prompt);
    res.json(obj);
  } catch (err) {
    console.error('❌ parse-prompt error:', err.message);
    res.status(500).json({ error: 'Failed to translate scheduling intent.' });
  }
});

app.post('/api/reparse-prompt', async (req, res) => {
  const { prompt, currentJob } = req.body;
  try {
    const obj = await parsePrompt(prompt, currentJob);
    res.json(obj);
  } catch (err) {
    console.error('❌ reparse-prompt error:', err.message);
    res.status(500).json({ error: 'Failed to interpret scheduling update.' });
  }
});

app.get('/api/jobs', (req, res) => {
  res.json(readJobsFromFile());
});

app.post('/api/jobs', (req, res) => {
  try {
    const jobs = readJobsFromFile();
    const incoming = normalizeJob(req.body);
    const idx = jobs.findIndex(j => j.id === incoming.id);
    const existingLogs = idx >= 0 ? jobs[idx].logs || [] : [];
    const job = { ...incoming, logs: existingLogs };

    if (!job.task) job.task = job.description || job.name;

    if (!isValidCron(job.schedule)) {
      return res.status(400).json({ error: 'Invalid cron schedule' });
    }

    if (idx >= 0) jobs[idx] = job;
    else jobs.push(job);

    writeJobsToFile(jobs);
    activateCronForJob(job);

    res.json({ success: true, job });
  } catch (err) {
    console.error('❌ jobs POST error:', err.message);
    res.status(500).json({ error: 'Failed to create or update job.' });
  }
});

app.post('/api/jobs/toggle-pause', (req, res) => {
  const { id } = req.body;
  const jobs = readJobsFromFile();
  const index = jobs.findIndex(j => j.id === id);

  if (index === -1) {
    return res.status(404).json({ error: 'Job not found' });
  }

  const currentStatus = jobs[index].status || 'active';
  jobs[index].status = currentStatus === 'active' ? 'paused' : 'active';
  writeJobsToFile(jobs);

  activateCronForJob(jobs[index]);
  res.json({ success: true, job: jobs[index] });
});

app.delete('/api/jobs', (req, res) => {
  const { id } = req.query;
  stopCronForJob(id);

  let jobs = readJobsFromFile();
  jobs = jobs.filter(job => job.id !== id);
  writeJobsToFile(jobs);

  res.json({ success: true });
});

